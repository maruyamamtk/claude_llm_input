# Anthropic API キー（必須）
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub Personal Access Token（任意・レート制限緩和用）
GITHUB_TOKEN=your-github-token-here

# Gmail API OAuth2 認証情報ファイルパス（任意）
GMAIL_CREDENTIALS_PATH=credentials.json

# Obsidianノートの保存先ディレクトリ（任意）
OBSIDIAN_NOTES_DIR=~/Desktop/obsidian_note/08_AINews

# CollectorSettings（任意）
# COLLECTOR__MAX_ARTICLES_PER_SOURCE=10
# COLLECTOR__MAX_RETRY_LOOPS=3
# COLLECTOR__SUMMARY_MAX_CHARS=500
# COLLECTOR__FILTER_MIN_SCORE=0.6
